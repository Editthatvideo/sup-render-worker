# --- Auth for incoming n8n -> worker calls ---
WORKER_API_KEY=change-me-to-a-long-random-string

# --- OpenAI (Whisper) ---
OPENAI_API_KEY=sk-...

# --- n8n callback (worker -> n8n webhook when render finishes) ---
N8N_CALLBACK_URL=https://scarousel.app.n8n.cloud/webhook/sup-render-done
N8N_CALLBACK_AUTH=          # optional Bearer token if your webhook requires one

# --- Google Drive (service account with write access to the output folder) ---
# Paste the FULL service-account JSON as one line, OR set a path to the file.
GDRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
GDRIVE_OUTPUT_FOLDER_ID=1AbCdEfG_folder_id_from_drive_url

# --- Render output tuning (optional) ---
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
HEADLINE_FONT_SIZE=72
CAPTION_FONT_SIZE=54
FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVu-Sans-Bold.ttf
WORK_DIR=/tmp/renders
